rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper: is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Routers: Only signed in users can view/manage (for simplicity in this demo, usually would be per user or admin)
    match /routers/{routerId} {
      allow read, write: if isSignedIn();
    }

    // Vouchers: Only signed in users
    match /vouchers/{voucherId} {
      allow read, write: if isSignedIn();
    }

    // Profiles: Only signed in users
    match /profiles/{profileId} {
      allow read, write: if isSignedIn();
    }

    // Resellers: Only signed in users
    match /resellers/{resellerId} {
      allow read, write: if isSignedIn();
    }

    // Sales: Only signed in users
    match /sales/{saleId} {
      allow read, write: if isSignedIn();
    }
  }
}
